# ─────────────────────────────────────────────────────────────────────────────
# Twilio API (WhatsApp)
# https://www.twilio.com/docs/whatsapp/quickstart
# ─────────────────────────────────────────────────────────────────────────────

# SID da sua conta Twilio (encontrado em https://console.twilio.com)
TWILIO_ACCOUNT_SID=sua_account_sid_aqui
TWILIO_AUTH_TOKEN=seu_auth_token_aqui

# Número WhatsApp da Twilio (número de testes ou produção)
TWILIO_WHATSAPP_NUMBER=+14155238886

# ─────────────────────────────────────────────────────────────────────────────
# Aplicação
# ─────────────────────────────────────────────────────────────────────────────

# Ambiente de execução
NODE_ENV=production

# Porta da aplicação NestJS
PORT=3000

# ─────────────────────────────────────────────────────────────────────────────
# Banco de Dados (PostgreSQL)
# ─────────────────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=bot-financas

# ─────────────────────────────────────────────────────────────────────────────
# Twilio API (WhatsApp)
# https://www.twilio.com/docs/whatsapp/api
# ─────────────────────────────────────────────────────────────────────────────

# SID da sua conta Twilio (encontrado em https://console.twilio.com)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Token de autenticação da Twilio (encontrado em https://console.twilio.com)
TWILIO_AUTH_TOKEN=your_auth_token_here

# Número WhatsApp da Twilio (sandbox para testes ou número de produção)
# Para testes, use: +14155238886
# Para produção: seu número de telefone dedicado (ex: +5511987654321)
TWILIO_WHATSAPP_NUMBER=+14155238886

# Seu número WhatsApp autorizado a usar o bot (com DDI, apenas dígitos)
# Exemplo: 5511999887766 (Brasil, São Paulo, celular)
WHATSAPP_AUTHORIZED_NUMBER=5511999999999

# ─────────────────────────────────────────────────────────────────────────────
# Google Sheets (mantém as mesmas configurações do Telegram)
# ─────────────────────────────────────────────────────────────────────────────

# Credenciais Google (arquivo JSON - path no container)
GOOGLE_APPLICATION_CREDENTIALS=/app/config/service-account.json

# ID da planilha Google Sheets
# Encontrado na URL: https://docs.google.com/spreadsheets/d/{SPREADSHEET_ID}/edit
GOOGLE_SHEETS_SPREADSHEET_ID=seu_spreadsheet_id_aqui

# ─────────────────────────────────────────────────────────────────────────────
# Aplicação
# ─────────────────────────────────────────────────────────────────────────────

# Ambiente de execução
NODE_ENV=production

# Porta da aplicação NestJS
PORT=3000

# ─────────────────────────────────────────────────────────────────────────────
# Banco de Dados (PostgreSQL)
# ─────────────────────────────────────────────────────────────────────────────

# Host do PostgreSQL
# Se rodar via docker-compose: use "postgres" (nome do serviço)
# Se banco externo/já existente: use o host real (ex: 192.168.1.10 ou db.servidor.com)
DB_HOST=localhost

# Porta padrão do PostgreSQL
DB_PORT=5432

# Usuário do banco
DB_USERNAME=postgres

# Senha do banco
DB_PASSWORD=postgres

# Nome do banco de dados (deve existir previamente em produção)
DB_NAME=bot_financa
